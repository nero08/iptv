# Copy to android/key.properties and fill in to sign a release build.
# Generate a keystore with:
#   keytool -genkey -v -keystore ~/zen-release.jks -keyalg RSA -keysize 2048 \
#     -validity 10000 -alias zen
storeFile=/absolute/path/to/zen-release.jks
storePassword=CHANGE_ME
keyAlias=zen
keyPassword=CHANGE_ME
